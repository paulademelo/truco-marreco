<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="@color/edit_text_bg" />
        </shape>
    </item>

    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="9dp" />
            <gradient
                android:angle="270"
                android:endColor="@color/edit_text_end"
                android:startColor="@color/edit_text_start"
                android:type="linear" />
        </shape>
    </item>

</layer-list>