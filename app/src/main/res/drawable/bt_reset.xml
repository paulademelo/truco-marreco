<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <solid android:color="@color/button_reset_dark" />
        </shape>
    </item>

    <item
        android:bottom="3dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:angle="270"
                android:centerColor="@color/gold_vintage"
                android:endColor="@color/dark_golden_rod"
                android:startColor="@color/primary_yellow"
                android:type="linear" />
        </shape>
    </item>
</layer-list>